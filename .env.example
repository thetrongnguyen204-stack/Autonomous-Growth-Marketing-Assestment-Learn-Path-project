# Firebase Web App Config
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FB_API_KEY=your-firebase-api-key
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project-id
VITE_FB_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=000000000000
VITE_FB_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx

# NOTE: The Gemini API key is NOT stored here.
# It is set as a Firebase Functions secret:
#   firebase functions:secrets:set GEMINI_KEY
